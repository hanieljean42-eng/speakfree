# ====================================
# CONFIGURATION SPEAKFREE - PRODUCTION
# ====================================
# Copiez ce fichier vers .env et remplissez les valeurs

# Environnement
NODE_ENV=production
PORT=3000

# Base de données MySQL
MYSQL_HOST=your-mysql-host.example.com
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database_name
MYSQL_SSL=true
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# Sécurité
JWT_SECRET=your_jwt_secret_key_here

# Super Admin Code
SUPER_ADMIN_CODE=your_super_admin_code_here

# API Anthropic (pour le chat IA - optionnel)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Frontend URL (pour CORS)
FRONTEND_URL=https://speakfree-school.netlify.app
